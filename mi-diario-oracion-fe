<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mi Diario de Oración y Fe · Tu espacio espiritual privado</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel:wght@400;500;600&family=Lato:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #c9a84c;
    --gold-light: #e8d49a;
    --gold-dark: #8b6914;
    --navy: #0d1b2a;
    --navy-mid: #162030;
    --navy-light: #1e2f42;
    --cream: #faf6ee;
    --cream-dark: #f0e8d8;
    --text-light: #d8c9a8;
    --text-mid: #9b8e78;
    --white: #ffffff;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--navy);
    color: var(--cream);
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 40px;
    background: rgba(13,27,42,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201,168,76,0.15);
  }
  .nav-logo {
    font-family: 'Cinzel', serif;
    font-size: 14px; font-weight: 500; letter-spacing: 2px;
    color: var(--gold); text-decoration: none;
  }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--text-light); text-decoration: none; transition: color .3s;
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta {
    font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 2px;
    color: var(--navy); background: var(--gold);
    padding: 8px 20px; border-radius: 2px; text-decoration: none;
    transition: background .3s;
  }
  .nav-cta:hover { background: var(--gold-light); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
    padding: 120px 20px 80px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 50% 0%, rgba(201,168,76,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 80%, rgba(201,168,76,0.05) 0%, transparent 60%);
  }
  .hero-cross {
    font-size: 36px; margin-bottom: 28px; opacity: .7;
    animation: float 4s ease-in-out infinite;
  }
  @keyframes float {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
  }
  .hero-badge {
    display: inline-block;
    font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 3px;
    color: var(--gold); border: 1px solid rgba(201,168,76,0.4);
    padding: 6px 16px; border-radius: 20px; margin-bottom: 28px;
    text-transform: uppercase;
  }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(42px, 7vw, 80px); font-weight: 300; line-height: 1.1;
    margin-bottom: 12px;
  }
  .hero h1 em {
    font-style: italic; color: var(--gold);
  }
  .hero-sub {
    font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 4px;
    color: var(--gold-light); opacity: .7; margin-bottom: 36px;
    text-transform: uppercase;
  }
  .hero p {
    max-width: 560px; font-size: 17px; line-height: 1.8;
    color: var(--text-light); margin-bottom: 48px;
  }
  .hero-buttons { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: 'Cinzel', serif; font-size: 12px; letter-spacing: 2px;
    color: var(--navy); background: var(--gold);
    padding: 14px 32px; border-radius: 2px; text-decoration: none;
    transition: all .3s; text-transform: uppercase;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(201,168,76,0.3); }
  .btn-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13px; letter-spacing: 1px;
    color: var(--gold-light); border: 1px solid rgba(201,168,76,0.35);
    padding: 14px 32px; border-radius: 2px; text-decoration: none;
    transition: all .3s;
  }
  .btn-secondary:hover { background: rgba(201,168,76,0.08); border-color: var(--gold); }

  /* phone mockup */
  .hero-mockup {
    margin-top: 70px;
    position: relative; display: inline-block;
  }
  .phone {
    width: 240px; height: 480px;
    background: var(--navy-light);
    border-radius: 32px;
    border: 2px solid rgba(201,168,76,0.3);
    box-shadow: 0 40px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(201,168,76,0.1), inset 0 1px 0 rgba(255,255,255,0.05);
    padding: 24px 18px;
    display: flex; flex-direction: column; gap: 12px;
    animation: float 5s ease-in-out infinite;
  }
  .phone-notch {
    width: 60px; height: 6px; background: var(--navy);
    border-radius: 4px; margin: 0 auto 8px;
  }
  .phone-quote {
    background: rgba(201,168,76,0.1); border-left: 2px solid var(--gold);
    padding: 10px 12px; border-radius: 0 6px 6px 0;
    font-family: 'Cormorant Garamond', serif; font-size: 12px; font-style: italic;
    color: var(--gold-light); line-height: 1.5;
  }
  .phone-label {
    font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--text-mid); padding-top: 4px;
  }
  .phone-textarea {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(201,168,76,0.15);
    border-radius: 8px; padding: 10px; flex: 1;
    font-family: 'Cormorant Garamond', serif; font-size: 12px;
    color: var(--text-light); line-height: 1.6;
  }
  .phone-emotions {
    display: flex; gap: 6px; justify-content: center;
  }
  .phone-emotion {
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center; font-size: 14px;
    cursor: pointer; transition: all .2s;
  }
  .phone-emotion.active {
    background: rgba(201,168,76,0.2); border-color: var(--gold);
  }
  .phone-btn {
    background: var(--gold); color: var(--navy);
    text-align: center; padding: 9px; border-radius: 6px;
    font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 1.5px;
  }

  /* ── DIVIDER ── */
  .divider {
    text-align: center; padding: 20px 0;
    color: rgba(201,168,76,0.3); font-size: 20px; letter-spacing: 12px;
  }

  /* ── STATS ── */
  .stats {
    background: rgba(201,168,76,0.06);
    border-top: 1px solid rgba(201,168,76,0.12);
    border-bottom: 1px solid rgba(201,168,76,0.12);
    padding: 50px 20px;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0; max-width: 900px; margin: 0 auto;
  }
  .stat {
    text-align: center; padding: 20px;
    border-right: 1px solid rgba(201,168,76,0.12);
  }
  .stat:last-child { border-right: none; }
  .stat-num {
    font-family: 'Cinzel', serif; font-size: 36px; font-weight: 600;
    color: var(--gold); display: block; line-height: 1;
  }
  .stat-label {
    font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--text-mid); margin-top: 8px; display: block;
  }

  /* ── SECTION ── */
  section { padding: 100px 20px; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-tag {
    font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 4px;
    color: var(--gold); text-transform: uppercase; margin-bottom: 16px; display: block;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 5vw, 56px); font-weight: 300; line-height: 1.15;
    margin-bottom: 20px;
  }
  .section-title em { font-style: italic; color: var(--gold); }
  .section-desc {
    font-size: 16px; line-height: 1.8; color: var(--text-light);
    max-width: 560px; margin-bottom: 60px;
  }

  /* ── FEATURES GRID ── */
  .features-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    gap: 2px; background: rgba(201,168,76,0.08);
  }
  .feature-card {
    background: var(--navy); padding: 40px 36px;
    transition: background .3s;
  }
  .feature-card:hover { background: var(--navy-mid); }
  .feature-icon { font-size: 32px; margin-bottom: 18px; display: block; }
  .feature-card h3 {
    font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 1.5px;
    color: var(--gold-light); margin-bottom: 12px; text-transform: uppercase;
  }
  .feature-card p { font-size: 14px; line-height: 1.8; color: var(--text-mid); }

  /* ── HOW IT WORKS ── */
  .steps { max-width: 700px; margin: 0 auto; }
  .step {
    display: flex; gap: 32px; align-items: flex-start;
    padding: 36px 0; border-bottom: 1px solid rgba(201,168,76,0.1);
  }
  .step:last-child { border-bottom: none; }
  .step-num {
    font-family: 'Cormorant Garamond', serif; font-size: 52px; font-weight: 300;
    color: rgba(201,168,76,0.25); line-height: 1; min-width: 60px;
  }
  .step-content h3 {
    font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 1.5px;
    color: var(--cream); margin-bottom: 10px; text-transform: uppercase;
  }
  .step-content p { font-size: 14px; line-height: 1.8; color: var(--text-mid); }

  /* ── IDEAL FOR ── */
  .ideal-bg {
    background: linear-gradient(135deg, var(--navy-mid) 0%, rgba(30,47,66,0.5) 100%);
    border-top: 1px solid rgba(201,168,76,0.1);
    border-bottom: 1px solid rgba(201,168,76,0.1);
  }
  .ideal-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px; margin-top: 50px;
  }
  .ideal-card {
    padding: 28px; border: 1px solid rgba(201,168,76,0.12); border-radius: 4px;
    transition: border-color .3s, transform .3s;
  }
  .ideal-card:hover { border-color: rgba(201,168,76,0.4); transform: translateY(-4px); }
  .ideal-card .icon { font-size: 28px; margin-bottom: 14px; display: block; }
  .ideal-card h3 {
    font-family: 'Cinzel', serif; font-size: 12px; letter-spacing: 1.5px;
    color: var(--gold-light); margin-bottom: 10px; text-transform: uppercase;
  }
  .ideal-card ul { list-style: none; }
  .ideal-card ul li {
    font-size: 13px; line-height: 1.7; color: var(--text-mid);
    padding-left: 16px; position: relative;
  }
  .ideal-card ul li::before {
    content: '·'; color: var(--gold); position: absolute; left: 0;
  }

  /* ── QUESTIONS ── */
  .questions-section { background: var(--navy); }
  .questions-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 16px; margin-top: 50px;
  }
  .question-card {
    background: rgba(201,168,76,0.05); border: 1px solid rgba(201,168,76,0.12);
    border-radius: 4px; padding: 24px 22px;
    font-family: 'Cormorant Garamond', serif; font-size: 18px; font-style: italic;
    color: var(--cream); line-height: 1.4;
    transition: all .3s;
  }
  .question-card:hover {
    background: rgba(201,168,76,0.1); border-color: rgba(201,168,76,0.35);
    transform: translateY(-3px);
  }
  .question-card span {
    display: block; font-family: 'Lato', sans-serif; font-size: 11px;
    font-style: normal; letter-spacing: 1.5px; color: var(--gold);
    margin-top: 12px; text-transform: uppercase;
  }

  /* ── PRIVACY ── */
  .privacy-section { background: var(--navy-mid); }
  .privacy-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0; border: 1px solid rgba(201,168,76,0.12); margin-top: 50px;
  }
  .privacy-item {
    padding: 36px 28px; border-right: 1px solid rgba(201,168,76,0.12);
    text-align: center;
  }
  .privacy-item:last-child { border-right: none; }
  .privacy-item .icon { font-size: 28px; margin-bottom: 14px; display: block; }
  .privacy-item h3 {
    font-family: 'Cinzel', serif; font-size: 12px; letter-spacing: 1.5px;
    color: var(--gold-light); margin-bottom: 10px; text-transform: uppercase;
  }
  .privacy-item p { font-size: 13px; line-height: 1.7; color: var(--text-mid); }

  /* ── EMOTIONS ── */
  .emotions-row {
    display: flex; flex-wrap: wrap; gap: 16px;
    justify-content: center; margin-top: 50px;
  }
  .emotion-pill {
    display: flex; align-items: center; gap: 10px;
    background: rgba(201,168,76,0.08); border: 1px solid rgba(201,168,76,0.2);
    padding: 14px 24px; border-radius: 100px;
    font-family: 'Cormorant Garamond', serif; font-size: 18px;
    color: var(--cream); transition: all .3s;
  }
  .emotion-pill:hover { background: rgba(201,168,76,0.15); transform: scale(1.04); }
  .emotion-pill .emoji { font-size: 22px; }

  /* ── CTA ── */
  .cta-section {
    text-align: center; padding: 120px 20px;
    position: relative; overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 50% 80% at 50% 50%, rgba(201,168,76,0.07) 0%, transparent 70%);
  }
  .cta-section h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 6vw, 68px); font-weight: 300; line-height: 1.15;
    margin-bottom: 24px;
  }
  .cta-section h2 em { font-style: italic; color: var(--gold); }
  .cta-section p {
    font-size: 17px; line-height: 1.8; color: var(--text-light);
    max-width: 520px; margin: 0 auto 48px;
  }
  .play-btn {
    display: inline-flex; align-items: center; gap: 14px;
    background: var(--gold); color: var(--navy);
    font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 2px;
    padding: 18px 40px; border-radius: 2px; text-decoration: none;
    transition: all .3s; text-transform: uppercase;
  }
  .play-btn:hover { background: var(--gold-light); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(201,168,76,0.35); }
  .play-btn svg { width: 22px; height: 22px; fill: var(--navy); }
  .disclaimer {
    margin-top: 20px; font-size: 12px; color: var(--text-mid); letter-spacing: .5px;
  }

  /* ── LEGAL ── */
  .legal {
    border-top: 1px solid rgba(201,168,76,0.1);
    padding: 40px 20px; background: rgba(0,0,0,0.2);
  }
  .legal-inner {
    max-width: 800px; margin: 0 auto; text-align: center;
  }
  .legal h4 {
    font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 2px;
    color: var(--gold); margin-bottom: 16px; text-transform: uppercase;
  }
  .legal p { font-size: 12px; line-height: 1.8; color: var(--text-mid); }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid rgba(201,168,76,0.1);
    padding: 28px 40px;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 16px;
  }
  .footer-logo {
    font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 2px; color: var(--gold);
  }
  .footer-links { display: flex; gap: 28px; }
  .footer-links a {
    font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--text-mid); text-decoration: none; transition: color .3s;
  }
  .footer-links a:hover { color: var(--gold); }
  .footer-copy { font-size: 11px; color: var(--text-mid); }

  /* ── FADE IN ── */
  .fade-in { opacity: 0; transform: translateY(24px); transition: opacity .7s ease, transform .7s ease; }
  .fade-in.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 700px) {
    nav { padding: 14px 20px; }
    .nav-links { display: none; }
    .stats { grid-template-columns: repeat(2,1fr); }
    .stat { border-right: none; border-bottom: 1px solid rgba(201,168,76,0.12); }
    footer { flex-direction: column; text-align: center; }
    .privacy-grid { grid-template-columns: 1fr 1fr; }
    .privacy-item { border-right: none; border-bottom: 1px solid rgba(201,168,76,0.12); }
  }
</style>
</head>
